{"file":"sobre-B2-t2pnJ.js","mappings":";;;;;;;;;;;;;;;;;;;AACA,eAAW;AAAA,MACT,OAAO;AAAA,MACP,aAAa;AAAA,IAAA,CACd;AAED,UAAM,OAAO,IAAI,KAAK;;;;;AAIf,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,gBAAY,MAAA,CAAA,CAAA,GAAA;AACT,YAAAC,mBAAA,uBAAA,EAAA,OAAA,MAAK;AAAA,QAAA,SAAAC,QAAjB,CAKa,GAAAC,QAAAC,UAAA,aAAA;;;;;cAJXC,YAGM,OAAA,EAHD,OAAM,2BAAA,GAA0B;AAAA,gBACnCA,YAAc,YAAV,OAAK;AAAA,gBACTA,YAAqB,WAAlB,gBAAc;AAAA,cAAA,CAAA;AAAA;;;;;;AAgD+BC,oBAAA,IAAL,MAAC;;;;;QAQhC,OAAM;AAAA,QAAiB,IAAG;AAAA,MAAA,GAAA;AAAA,yBAApC,CAAiG,GAAAH,QAAAC,UAAA,aAAA;;;;;8BAAjD,0BAAwB;AAAA,cAAAC,YAAc,cAAR,GAAC;AAAA,YAAA;AAAA;;;;iWAYnCE,MAAA,IAAA,KAAI,aAAA,CAAA,qBAAOA,MAAA,IAAA,IAAI,wBAAA,EAAA,CAAA,oCAAA;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_withCtx","_push","_parent","_createVNode","_ssrRenderList","_unref"],"sources":["../../../../pages/sobre.vue"],"sourcesContent":["<script setup lang=\"ts\">\nuseSeoMeta({\n  title: 'Sobre — Pense Assim',\n  description: 'Conheça a trajetória e a metodologia da Pense Assim.'\n})\n\nconst sent = ref(false)\n</script>\n\n<template>\n  <div class=\"inner-page\">\n    <SiteHeader inner>\n      <div class=\"container page-hero-copy\">\n        <h1>Sobre</h1>\n        <p>Nossa história</p>\n      </div>\n    </SiteHeader>\n\n    <main>\n      <section class=\"content-section\">\n        <div class=\"container\">\n          <div class=\"story-grid\">\n            <div>\n              <h2>Nossa trajetória</h2>\n              <p>A Pense nasceu para aproximar estratégia e criação. Reunimos talentos de publicidade, design, fotografia, vídeo e marketing para construir marcas mais relevantes, consistentes e preparadas para crescer.</p>\n              <p>Mais do que executar peças, mergulhamos nos negócios. Entendemos contextos e transformamos ideias em comunicação que as pessoas reconhecem, sentem e lembram.</p>\n            </div>\n            <div class=\"story-visual\" />\n          </div>\n\n          <div class=\"story-grid\">\n            <div class=\"story-visual story-visual--sphere\" />\n            <div>\n              <h2>Por que 360°?</h2>\n              <p>Porque uma marca não acontece em um único canal. Ela é construída em cada conversa, campanha, busca, embalagem, vídeo e experiência.</p>\n              <p>Estratégia, branding, conteúdo, audiovisual e mídia trabalham juntos para fortalecer a identidade e fazer cada investimento colaborar com o próximo.</p>\n            </div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"showreel\">\n        <div class=\"showreel-content\">\n          <span>Ideias precisam<br>ser <em>sentidas.</em></span>\n          <button class=\"play-button\" aria-label=\"Reproduzir showreel\">\n            <svg viewBox=\"0 0 80 80\"><circle cx=\"40\" cy=\"40\" r=\"39\" /><path d=\"m33 27 22 13-22 13Z\" /></svg>\n          </button>\n        </div>\n      </section>\n\n      <section class=\"method-section\">\n        <div class=\"container method-layout\">\n          <div class=\"method-copy\">\n            <h2>Metodologia de<br>trabalho</h2>\n            <p>Um processo colaborativo que transforma complexidade em decisões claras.</p>\n            <ul>\n              <li>Imersão no negócio, público e objetivos.</li>\n              <li>Diagnóstico dos desafios prioritários.</li>\n              <li>Estratégia criativa conectada a resultados.</li>\n              <li>Produção e evolução contínua.</li>\n            </ul>\n          </div>\n          <div class=\"method-graphic\"><span v-for=\"i in 5\" :key=\"i\" /></div>\n        </div>\n      </section>\n\n      <section class=\"page-cta\">\n        <div class=\"container\">\n          <h2>Somos especialistas<br>em comunicação</h2>\n          <p>Unimos marketing, publicidade, design, audiovisual e mídia para construir uma comunicação inteira.</p>\n          <NuxtLink class=\"outline-button\" to=\"/#contato\">Vamos trabalhar juntos? <span>→</span></NuxtLink>\n        </div>\n      </section>\n\n      <section class=\"newsletter\">\n        <div class=\"container\">\n          <h2>Receba nossos<br>conteúdos:</h2>\n          <p>Ideias, referências e movimentos da comunicação.</p>\n          <form class=\"newsletter-form\" @submit.prevent=\"sent = true\">\n            <input placeholder=\"Nome\" required>\n            <input type=\"email\" placeholder=\"E-mail\" required>\n            <button>Inscreva-se</button>\n            <p class=\"form-status\" :class=\"{ visible: sent }\">{{ sent ? 'Inscrição recebida.' : '' }}</p>\n          </form>\n        </div>\n      </section>\n    </main>\n\n    <SiteFooter />\n  </div>\n</template>\n"],"version":3}