>Sobre</NuxtLink>\n        <NuxtLink to=\"/#insights\" @click=\"open = false\">Insights</NuxtLink>\n        <NuxtLink to=\"/#contato\" @click=\"open = false\">Contato</NuxtLink>\n        <NuxtLink class=\"mobile-menu-cta\" to=\"/#contato\" @click=\"open = false\">Faça um orçamento →</NuxtLink>\n      </div>\n      <button v-if=\"open\" class=\"menu-backdrop\" type=\"button\" aria-label=\"Fechar menu\" @click=\"open = false\" />\n      <NuxtLink class=\"nav-cta\" to=\"/#contato\"><span class=\"nav-cta-icon\">◉</span>Faça um orçamento</NuxtLink>\n    </nav>\n    <slot />\n  </header>\n</template>\n","<template>\n  <footer class=\"footer\">\n    <div class=\"container footer-main\">\n      <div class=\"footer-about\">\n        <h2>Pense Assim</h2>\n        <p>Transformamos conteúdo em design, fotografia, vídeo, publicidade e comunicação de resultados. Pensamos o seu negócio para que seus potenciais clientes lembrem da sua marca nas decisões de consumo.</p>\n        <div class=\"social-links\" aria-label=\"Redes sociais\">\n          <a href=\"#\" aria-label=\"Facebook\">f</a>\n          <a href=\"#\" aria-label=\"YouTube\">▶</a>\n          <a href=\"#\" aria-label=\"LinkedIn\">in</a>\n        </div>\n      </div>\n\n      <nav class=\"footer-links\" aria-label=\"Links do rodapé\">\n        <h2>Navegação</h2>\n        <NuxtLink to=\"/cases\">Cases</NuxtLink>\n        <NuxtLink to=\"/solucoes\">Soluções</NuxtLink>\n        <NuxtLink to=\"/sobre\">Sobre</NuxtLink>\n        <NuxtLink to=\"/#contato\">Contato</NuxtLink>\n      </nav>\n\n      <div class=\"footer-contact\">\n        <h2>Contatos</h2>\n        <dl>\n          <div><dt>WhatsApp</dt><dd><a href=\"https://wa.me/5543991619048\" target=\"_blank\" rel=\"noopener\">+55 43 99161-9048</a></dd></div>\n          <div><dt>Email</dt><dd><a href=\"mailto:fabio@penseassim.com.br\">fabio@penseassim.com.br</a></dd></div>\n          <div><dt>Endereço</dt><dd>Rua Dr. Elias Cesar, 55 -<br>sala 501, Londrina - PR</dd></div>\n        </dl>\n      </div>\n    </div>\n\n    <div class=\"footer-legal\">\n      <div class=\"container footer-bottom\">\n        <span>© Copyright 2025 by <strong>Pense</strong></span>\n        <span class=\"developed\">Desenvolvido por: <b class=\"mini-brand\">PEN<br>SE</b></span>\n        <span>Política de Privacidade · Relatório de Transparência e Igualdade Salarial</span>\n      </div>\n    </div>\n  </footer>\n</template>\n","export const site = {\n  name: 'Pense Assim',\n  url: 'https://www.penseassim.com.br',\n  description: 'Comunicação 360°, branding, marketing, audiovisual e mídia para marcas que querem crescer com estratégia.',\n  phone: '+55 43 99161-9048',\n  email: 'fabio@penseassim.com.br',\n  address: 'Rua Dr. Elias Cesar, 55 - sala 501, Londrina - PR'\n}\n"],"version":3}